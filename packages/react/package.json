{
  "name": "@superlend/react-sdk",
  "version": "0.2.0",
  "description": "React widget and hooks for SuperLend",
  "license": "GPL-3.0-only",
  "author": "SuperLend",
  "repository": {
    "type": "git",
    "url": "https://github.com/superlend/superlend-sdk",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/superlend/superlend-sdk/tree/main/packages/react",
  "keywords": [
    "superlend",
    "defi",
    "lending",
    "react",
    "widget"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "format": "biome check --write src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@superlend/sdk": "workspace:*",
    "motion": "^12.35.2"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^20.8.3",
    "msw": "^2.12.10",
    "tsup": "^8.5.1",
    "vitest": "^4.0.18"
  },
  "peerDependenciesMeta": {
    "viem": {
      "optional": true
    },
    "wagmi": {
      "optional": true
    }
  }
}
