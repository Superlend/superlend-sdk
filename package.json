{
  "name": "superlend-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "SuperLend SDK monorepo",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter nextjs-example test:e2e",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "typecheck": "pnpm -r typecheck",
    "storybook": "pnpm --filter storybook dev",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "docs:generate": "typedoc"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.18.6",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "typedoc": "^0.28.9",
    "vitest": "^3.2.4",
    "msw": "^2.11.3",
    "playwright": "^1.55.0"
  }
}
